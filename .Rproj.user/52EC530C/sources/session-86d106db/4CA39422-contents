#---------------------------------------------------------------------------------------
#!                Exercice 1: Inspecting non-stationnarity graphically                !
#---------------------------------------------------------------------------------------

# a) Import the time series of average oil price from the excel file "OilPriceAv.xlsx" and attribute a class xts to it. 
Mydata <- read_excel("OilPriceAv.xlsx")
Mydata$date <- as.Date(as.yearmon(Mydata$date,format = "%Ym%m"))
oilprice <- xts(x = Mydata[,2:ncol(Mydata)], order.by = Mydata$date)

# b) Plot the time series "oilprice" and inspect the trend. Does "oilprice" look stationnary or not?
plot(oilprice)
# série non stationnaire en moyenne => test RU (TS ou DS ???)

# c) Take the logarithm of "oilprice" using log(). Call this new time series "lop" and plot it.
lop <- log(oilprice)
plot(lop)

# d) Use acf2() from astsa to plot the sample P/ACF pair for lop. Comment.
acf2(lop)
# ACF : autoc très significative + décroissance très lente
# PACF : h=1 très significatif, le reste non-significatif
# => caractéristique typique d'une série DS.

#---------------------------------------------------------------------------------------
#!                        Exercice 2: Unit root test for lop                           !
#---------------------------------------------------------------------------------------
# Notice: critical value for trend and constant for ADF and PP test
#   t-trend(DF) = 2.79 (resp. 3.49) at 5% (resp. 1%) level for 250obs
#   t-drift(DF) = 2.53 (resp. 3.19) at 5% (resp. 1%) level for 250obs

#**************** I) ADF unit root test  ********************
# Specification of the ur.df() test:
#   - Model 3 (type = "trend"),
#   - Model 2 (type = "drift"),
#   - Model 1 (type = "none"),

# a) Proceed to the ADF unit root test for "lop". Choose 5% significance level to make your decision.
summary(ur.df(lop, type = "trend", lags = 12, selectlags="AIC")) 
# modèle 3 : type= "trend"
# paramètre de troncature : AIC critère (prévision), max retard = 12
# seuil de significativité : 5%
# Interprétation : 
# - on commence par tester la tendance TS ("tt")
#   * t_stat(tt) = 3,121 > t_tab(DF à 5%) = 2,79 => on rejette H0 = la tendance TS
#     est significative => on garde le modèle 3 => on passe au test de RU
# - on test la RU :
# t-stat (rho de z.lag.1) = -3,7315 < t_tab(DF) = -3,43 => on rejette H0
# le rejet de H0 (présence de RU) => la série ne possède pas de RU (pas DS)
# - Conclusion : TS est significatif + pas de RU (pas DS) => série est TS si on se réfère aux données de départ (5% de significativité)
# b) Proceed to the ADF unit root test for "lop". Choose 1% significance level to make your decision.
summary(ur.df(lop, type = "trend", lags = 12, selectlags="AIC")) 
# Interprétation : 
# - on commence par tester la tendance TS ("tt")
#   * t_stat(tt) = 3,121 < t_tab(DF à 1%) = 3,49 => on ne rejette pas H0 : tt
#     est non significative => on abandonne le modèle 3 => on passe au modèle 2

summary(ur.df(lop, type = "drift", lags = 12, selectlags="AIC")) 

# Interprétation : 
# - on commence par tester la constante ("Intercept")
#   * t_stat(tt) = 2,396 < t_tab(DF à 1%) = 3,19 => on accepte H0 = Intercept
#     est non significative => on abandonne le modèle 2 => on passe au modèle 1



summary(ur.df(lop, type = "none", lags = 12, selectlags="AIC")) 

# Test de RU avec le modèle sans constante ni tendance :
# Attention test unilatéral à gauche, règle de décision inversée + on ne prend pas la valeur absolue
# t-stat(phi) = 1,1222 > t-DF(1%) = -2,58 => on accepte H0 => il y a RU 
# Conclusion : Pas de TS (modèle3) + Ru (modèle 1) => Processus DS
 
# Remarque pour le test ADF :
# Avantage : c'est la base de tout test de RU
# Inconvénients :
# 1) très sensible au paramètre de troncature p (=> Test PP)
# 2) Il y a un biais pour l'H0 (de RU) (=> Test KPSS)
# 3) ne tient pas compte des ruptures dans la série  (=> Test de (Perron))




#**************** II) PP unit rool test   ********************
# Specification of the ur.pp() test:
#   - Model 3 (model = "trend")
#   - Model 2 (model = "constant")
#   - PP test statistic (type="Z-tau")
#   - Truncation parameter (I_4: lags = "short", I_12 = lags="long")

# Proceed to the PP unit root test for "lop".
summary(ur.pp(lop, model = "trend", type="Z-tau", lags = "short")) 

# Interprétation : 
# - on commence par tester la tendance TS ("trend")
#   * t_stat(trend) = 1,911 < t_tab(DF à 5%) = 3,49 => on accepte H0 = tt
#     est non significative => on abandonne le modèle 3 => on passe au modèle 2

test <- ur.pp(lop, type = "Z-tau", model = "constant", lags = "short")
summary(test)

# seuil de significativité : 1%
# Interprétation : 
# - on commence par tester la constante ("Intercept")
#   * t_stat(Intercept) = 1,575 < t_tab(DF à 5%) = 2,79 => on ne rejette pas H0 = la tendance TS
#     est significative => on garde le modèle 3 => on passe au test de RU

# Rq : pas de modèle sur R avec ur.pp
# test de RU :
#" Attention : - test unilatéral J'AI PAS LA SUITE

# Remarque pour le test PP :
# Avantage : c'est la base de tout test de RU
# Inconvénients :
#  2) Il y a un biais pour l'H0 (de RU) (=> Test KPSS)
#  3) ne tient pas compte des ruptures dans la série (=> test de (Peron) Zivot-Andrews)

#**************** III) KPSS unit rool test   ********************
# Specification of the ur.kpss() test:
#   - Model "avec derive" (type = "tau")
#   - Model "sans derive" (type = "mu")
#   - Truncation parameter (I_4: lags = "short", I_12 = lags="long")

# Proceed to the KPSS unit root test for "lop".
summary(ur.kpss(lop, type="tau", lags = "short"))  # Modèle 3 

# Test RU :
# t-stat = 0,3178 > t-val(1%) = 0,216 => on rejette H0 => il y a RU

summary(ur.kpss(lop, type="mu", lags = "short")) # Modèle 2
# Test RU :
# t-stat = 3,6801 >>>>> t-val(1%) = 0,739 => on rejette H0 => il y a RU

# Conclusion générale :
# - Test ADF : à 5% pas de RU MAIS à 1% il y a RU
# - Test PP et Test KPSS (à 1% ou à 5%) : il y a RU pour lop => lop est bien DS


#---------------------------------------------------------------------------------------
#!                 Exercice 4: Unit root test and structural break                     !
#---------------------------------------------------------------------------------------

# a) Plot the time series "oilprice" and inspect the trend. Does "oilprice" present a structural break? If yes, for which type?
plot(oilprice)

# pic 2008-07-01 pour 132.55
# Modèle : pronbablement Modèle A avec une rupture en 2008-07
#      (mais peut-être aussi une rupture de tendance, à confirmer)

# b) Create a dummy variable which value is 0 before 2008m8 and 1 from 2008m8. Call this times series d2008m8.
d2008m8 <- lop
d2008m8[index(lop)] <- 0
d2008m8[index(lop) >= "2008-08-01"] <- 1

# c) Generate a linear trend using seq_along() that is used for the auxiliary regression in Perron test.
mytrend <- seq_along(lop)

# d) Proceed to the first stage auxiliary regression in Perron test. Regress lop on a constant, mytrend and d2008m8.
myols <- lm(coredata(lop) ~ mytrend + coredata(d2008m8))
summary(myols)

# e) Save the residuals from the auxiliary regression as "resid_perron". Attribute a class xts to it.
resid_perron <- xts(residuals(myols),index(lop))

# test de RU ou Modélisation
# Inconvénient du Test de Perron :
# le test ne permet que de traiter une seule rupture
# - on a choisit de façon exogène la date de rupture
# idée : avoir un test qui permet de traiter plusieurs ruptures et de déterminer 
#        de façon endogène la rupture => test de Zivot-Andrews

#---------------------------------------------------------------------------------------
#!             Exercice 6: Unit root test and endogenous structural break              !
#---------------------------------------------------------------------------------------
# Specification of the ur.za(), the Zivot and Andrews unit root test which allows a break at
# an "unknown" point in either the intercept, the linear trend or in both:
#   - Model A: break in the intercept (model="intercept")
#   - Model B: break in the trend (model="trend")
#   - Model C: break in the intercept and the trend (model="both")

# a) Using our knowledge of "lop" from preceding tests (Model A), proceed to ZA of "lop".
summary(ur.za(lop, model="intercept"))
# test de RU Zivot-Andrews: (même H0 que ADF, même règle de décision)
#   t-stat => -3.9022 > t-tabulée(1%) = -5.34 => on ne rejette pas H0
#        => RU + rupture en niveau

plot(ur.za(lop,model="intercept")) # test avec plusieurs ruptures
# ligne noire = t-stat
# ligne verte-bleue_rouge = t-tabulée(5%, 2.5% et 1%)
# règle de décision : si ligne noire "au-dessus" des seuils => RU (+ rupture)

# b) Identify the date corresponding to the break point obtain in ZA test.
index(lop[127])

# c) Proceed to ZA test for "lop" using the specification in Model C (useful if one doesn't 
#    want to impose any "a priori" on the specification of "lop")
summary(ur.za(lop, model="both"))



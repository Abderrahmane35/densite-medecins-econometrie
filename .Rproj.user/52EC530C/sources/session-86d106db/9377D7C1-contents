library(xts)
library(readxl)
library(astsa)
library(ggfortify)
library(forecast)
library(fpp2)
library(seasonal)

# I - Manipulation des séries

### 1 ###

Mydata <- read_excel("Donnees.xlsx")
View(Mydata)
Mydata$dates <- as.Date(as.yearmon(Mydata$dates,format = "%YM%m"))

### 2 ### 

ICA <- xts(x = Mydata[,2:ncol(Mydata)], order.by = Mydata$dates)

### 3 ###

plot(ICA) 

# Commentaire : on observe une tendance globale qui augmente donc cette série n'est pas stationnaire en moyenne.
# puis on voit un pic négatif chaque année au mois de mars, donc on y voit une saisonnalité mensuelle.

### 4 ###

sum(is.na(ICA)) #il y a bien une valeur manquante
ICA[is.na(ICA)] <- 95.89

# II - Saisonnalité

### 1 ###

ICAts <- ts(coredata(ICA), start=c(1999,1),freq=12)
plot(ICAts)

acf2(ICAts)
ggseasonplot(ICAts)

# Selon moi, la saisonnalité est plutôt de type multiplicative car les écarts ne sont pas constants.

### 2 ###

log_ICAts <- log(ICAts)
ICAts_sa <- diff(log_ICAts, lag = 12)
plot(ICAts_sa)

### 3 ###

ICA_x11 <- seas(ICAts,x11="")

ICAcvs <- seasadj(ICA_x11)

autoplot(ICAcvs) +
  ggtitle("décomposition saisonnière de ICA")


# III - Racine unité

### 1 ###

acf2(ICAcvs)

# commentaire : on observe une décroissance légère des pics dans l'ACf ce qui indique une non-stationnarité en moyenne de la série 
# on observe un premier pic très significatif dans le graphe du PACF ce qui implique la présence d'une racine unitaire.

### 2 ###

test <- ur.kpss(lop, type="tau", lags = "long")
summary(test)

# à travers ce test nous observons que le t-test = 0.1602 qui est supérieure à la valeur critique à 5% qui est égale à 0.146
# ainsi au regard de H0, on rejette H0 et donc la série est NS
# Au seuil de 1%, 0,1602 < 0,216 donc, à ce seuil la série est stationnaire.

### 3 ###

summary(ur.za(lop, model="intercept"))
# il y a potentiellement une rupture à la 127ème valeur, la variable du est significative (p-value = 0.000140) et correspond au changement de niveau 
# donc c'est une rupture de niveau.

